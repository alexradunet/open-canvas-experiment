{
  "$schema": "https://opencode.ai/config.json",
  "model": "openai/gpt-5.6-sol",
  "small_model": "qwencloud-token-plan/qwen3.6-flash",
  "default_agent": "lead",
  "share": "disabled",
  "skills": {
    "paths": [".agents/skills"]
  },
  "instructions": [
    "AGENTS.md",
    "CONTEXT.md",
    "docs/agents/*.md"
  ],
  "provider": {
    "qwencloud-token-plan": {
      "npm": "@ai-sdk/anthropic",
      "name": "QwenCloud Token Plan Individual",
      "options": {
        "baseURL": "https://token-plan.ap-southeast-1.maas.aliyuncs.com/compatible-mode/v1",
        "apiKey": "{file:~/.config/opencode/qwen-token-plan.key}",
        "timeout": 300000
      },
      "models": {
        "qwen3.8-max-preview": {
          "name": "Qwen3.8 Max Preview",
          "reasoning": true,
          "tool_call": true,
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"]
          },
          "limit": {
            "context": 983616,
            "output": 131072
          },
          "options": {
            "thinking": {
              "type": "enabled",
              "budgetTokens": 99072
            },
            "temperature": 0.6,
            "reasoning": true
          }
        },
        "qwen3.7-plus": {
          "name": "Qwen3.7 Plus",
          "reasoning": true,
          "tool_call": true,
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"]
          },
          "limit": {
            "context": 1000000,
            "output": 65536
          },
          "options": {
            "thinking": {
              "type": "enabled",
              "budgetTokens": 8192
            }
          }
        },
        "qwen3.6-flash": {
          "name": "Qwen3.6 Flash",
          "tool_call": true,
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"]
          },
          "limit": {
            "context": 1000000,
            "output": 32768
          }
        },
        "glm-5.2": {
          "name": "GLM-5.2",
          "reasoning": true,
          "tool_call": true,
          "limit": {
            "context": 1000000,
            "output": 16384
          },
          "options": {
            "thinking": {
              "type": "enabled",
              "budgetTokens": 8192
            }
          },
          "variants": {
            "max": {
              "thinking": {
                "type": "enabled",
                "budgetTokens": 8192
              },
              "effort": "max"
            }
          }
        }
      }
    }
  },
  "agent": {
    "explore": {
      "model": "qwencloud-token-plan/qwen3.6-flash"
    },
    "general": {
      "model": "qwencloud-token-plan/qwen3.6-flash"
    },
    "title": {
      "model": "qwencloud-token-plan/qwen3.6-flash"
    },
    "summary": {
      "model": "qwencloud-token-plan/qwen3.6-flash"
    }
  },
  "permission": {
    "*": "allow",
    "external_directory": {
      "*": "allow",
      "/tmp/balaur-workers/**": "allow",
      "~/.config/opencode/qwen-token-plan.key": "deny"
    },
    "bash": {
      "*": "allow",
      "git status*": "allow",
      "git diff*": "allow",
      "git log*": "allow",
      "git show*": "allow",
      "git rev-parse*": "allow",
      "node --check*": "allow",
      "node --test*": "allow",
      "git reset*": "deny",
      "git checkout --*": "deny",
      "git clean*": "deny",
      "git push --force*": "deny"
    }
  }
}
